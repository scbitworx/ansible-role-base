# {{ ansible_managed }}
# ~/.config/profile — managed by ansible-role-base

# Add ~/.local/bin to PATH
if [ -d "${HOME}/.local/bin" ]; then
  PATH="${HOME}/.local/bin:${PATH}"
fi

# Source bashrc for interactive login shells
if [ -n "$BASH_VERSION" ] && [ -f "${HOME}/.config/bash/bashrc" ]; then
  . "${HOME}/.config/bash/bashrc"
fi

# Source profile drop-in fragments
if [ -d "${HOME}/.config/profile.d" ]; then
  for f in "${HOME}/.config/profile.d"/*.conf; do
    [ -r "$f" ] && . "$f"
  done
fi
